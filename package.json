  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.12",
    "@cloudflare/workers-types": "^4.20260603.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "wrangler": "^4.97.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "zod": "^4.4.3"
  }
}
