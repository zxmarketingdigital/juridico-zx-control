{
  "name": "juridico-zx-control",
  "version": "0.1.0",
  "description": "Jurídico ZX Control — pacote de nicho imobiliário (5 agentes de WhatsApp).",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
